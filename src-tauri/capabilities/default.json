{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/tauri/v2/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capability for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "http:default",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-write-text-file",
    "deep-link:default",
    "deep-link:allow-get-current",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://auth.atlassian.com/*" }
      ]
    }
  ]
}
